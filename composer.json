{
    "name": "al3x5/xbot",
    "description": "Build powerful Telegram bots with ease",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "telegram",
        "bot",
        "telegram-bot",
        "telegram-api",
        "webhook",
        "framework"
    ],
    "homepage": "https://github.com/al3x5dev/xbot",
    "authors": [
        {
            "name": "al3x5dev",
            "email": "al3x5.dev@gmail.com",
            "homepage": "https://t.me/al3x5dev"
        }
    ],
    "support": {
        "issues": "https://github.com/al3x5dev/xbot/issues",
        "source": "https://github.com/al3x5dev/xbot"
    },
    "require": {
        "php": ">=8.2",
        "mk4u/http": "^1.2",
        "monolog/monolog": "^3.6",
        "mk4u/cache": "^0.4",
        "symfony/console": "^7.2"
    },
    "require-dev": {
        "al3x5/xbot-devkit": ">0.2",
        "symfony/var-dumper": "^7.3",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Al3x5\\xBot\\": "src/",
            "Bot\\": "bot/"

        },
        "files": [
            "src/helpers.php"
        ]
    },
    "bin": [
        "xbot"
    ],
    "archive": {
        "exclude": [
            "/.gitignore",
            "/.gitattributes",
            "/.github",
            "/docs",
            "/phpunit.xml",
            "/tests"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
